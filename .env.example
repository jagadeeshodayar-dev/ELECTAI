# Election Assistant API Keys

# Firebase Auth web config for Cloud Run runtime env.
# These values are public Firebase web-app identifiers, but they still must match your Firebase project.
FIREBASE_WEB_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_APP_ID=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MEASUREMENT_ID=""

# Gemini API Key (already handled by AI Studio)
GEMINI_API_KEY=""

# Google Civic Information API Key
# Get one at: https://console.cloud.google.com/apis/library/civicinfo.googleapis.com
GOOGLE_CIVIC_API_KEY=""

# Optional server-side Google Geocoding key for cleaning up spoken or partial addresses
# Recommended for India mode address normalization.
GOOGLE_GEOCODING_API_KEY=""
GOOGLE_MAPS_API_KEY=""

# Optional: Gemini model override
GEMINI_MODEL="gemini-2.5-flash"

# Optional: Firestore Admin for local server-side writes
FIRESTORE_DATABASE_ID="(default)"
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Speech-to-Text server credentials. Use one:
# 1) service account JSON for the official client, or
# 2) a server-only API key with Speech-to-Text API enabled.
GOOGLE_APPLICATION_CREDENTIALS_JSON=""
SPEECH_TO_TEXT_API=""

# App URL (automatically injected in production)
APP_URL="http://localhost:3000"
