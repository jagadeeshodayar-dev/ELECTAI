{
  "entities": {
    "UserSession": {
      "title": "User Session",
      "description": "Stores voter information and current progress for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "address": { "type": "string" },
        "electionData": { "type": "object" },
        "currentStep": { "type": "integer" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["id", "address", "electionData", "currentStep", "updatedAt"]
    }
  },
  "firestore": {
    "/sessions/{sessionId}": {
      "schema": "UserSession",
      "description": "Voter guidance sessions."
    }
  }
}
